package components

import "web/src/client"

templ TaskItem(task client.Task) {
	<li class={ "task-item", templ.KV("completed", task.IsCompleted()) }>
		<span class="task-status">
			if task.IsCompleted() {
				{ "\u2705" }
			} else {
				{ "\u2b1c" }
			}
		</span>
		<div class="task-content">
			<strong>{ task.Title }</strong>
			<span class="task-desc">{ task.Description }</span>
		</div>
	</li>
}
