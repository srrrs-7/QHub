package components

templ AddForm() {
	<form
		class="add-task"
		hx-post="/partials/tasks"
		hx-target="#tasks-container"
		hx-swap="outerHTML"
	>
		<input
			type="text"
			name="title"
			placeholder="Task title"
			required
		/>
		<input
			type="text"
			name="description"
			placeholder="Description (optional)"
		/>
		<button type="submit">
			Add Task
			<span class="htmx-indicator">...</span>
		</button>
	</form>
}
