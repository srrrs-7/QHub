package templates

templ IndexPage() {
	@Layout(PageData{}) {
		<div class="empty-state" style="min-height: 60vh;">
			<span class="material-symbols-outlined" style="font-size: 64px;">edit_note</span>
			<div class="empty-state__title" style="font: var(--md-sys-typescale-headline-small);">Welcome to PromptLab</div>
			<div class="empty-state__desc">
				LLM prompt version management, quality tracking, and improvement cycles.
			</div>
		</div>
	}
}
