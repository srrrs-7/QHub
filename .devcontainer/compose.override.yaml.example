services:
  dev:
    environment:
      DB_URI: postgresql://postgres:postgres@db:5432/test?sslmode=disable
      DB_MIGRATE_URI: postgresql://postgres:postgres@db:5432?sslmode=disable
      CACHE_URI: redis://cache:6379
      QUEUE_URI: redis://queue:9324
      EMBEDDING_URI: http://embedding:80
      OLLAMA_URI: http://host.docker.internal:11434
      ENABLE_FIREWALL: "true"  # Set to "true" to enable network firewall (restricts outbound to allowlisted domains)
  db:
    environment:
      POSTGRES_DB: test
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - 5432:5432

  cache:
    ports:
      - 6379:6379
  
  queue:
    ports:
      - 9324:9324

  embedding:
    ports:
      - 8081:80
    # ARM64 hosts (Apple Silicon, AWS Graviton, etc.) must override the image and platform:
    # image: ghcr.io/huggingface/text-embeddings-inference:cpu-arm64-1.8
    # platform: linux/arm64